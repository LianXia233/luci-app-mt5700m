#!/bin/sh

uci -q get mt5700m.settings >/dev/null 2>&1 || uci -q set mt5700m.settings='mt5700m'
uci -q set mt5700m.settings.enabled="${MT5700M_ENABLED:-$(uci -q get mt5700m.settings.enabled || echo 1)}"
uci -q set mt5700m.settings.mode="$(uci -q get mt5700m.settings.mode || echo auto)"
uci -q set mt5700m.settings.at_port="$(uci -q get mt5700m.settings.at_port || echo '')"
uci -q set mt5700m.settings.host="$(uci -q get mt5700m.settings.host || echo 192.168.8.1)"
uci -q set mt5700m.settings.port="$(uci -q get mt5700m.settings.port || echo 20249)"
uci -q set mt5700m.settings.timeout="$(uci -q get mt5700m.settings.timeout || echo 8)"

# Migrate only the user-owned MT5700M profile from an existing QModem
# installation. Discovery state and generic vendor settings are intentionally
# not copied into the dedicated manager.
if ! uci -q get mt5700m.connection >/dev/null 2>&1; then
	uci -q set mt5700m.connection='connection'
	uci -q set mt5700m.connection.enabled='1'
	uci -q set mt5700m.connection.pdp_type='ipv4v6'
	uci -q set mt5700m.connection.auth='none'
	uci -q set mt5700m.connection.metric='50'

	for section in $(uci -q show qmodem 2>/dev/null | sed -n "s/^qmodem\.\([^.=]*\)=modem-device$/\1/p;s/^qmodem\.\([^.=]*\)='modem-device'$/\1/p"); do
		identity="$(uci -q get qmodem.${section}.name || true) $(uci -q get qmodem.${section}.alias || true)"
		case "${identity}" in *[Mm][Tt]5700*) ;; *) continue ;; esac
		for option in enable_dial apn pdp_type auth username password metric; do
			value="$(uci -q get qmodem.${section}.${option} || true)"
			[ -n "${value}" ] || continue
			[ "${option}" != 'enable_dial' ] || option='enabled'
			uci -q set "mt5700m.connection.${option}=${value}"
		done
		for value in $(uci -q get qmodem.${section}.dns_list 2>/dev/null); do
			uci -q add_list "mt5700m.connection.dns_list=${value}"
		done
		break
	done
fi
uci -q commit mt5700m

if [ -z "${IPKG_INSTROOT:-}" ]; then
	rm -f /tmp/luci-indexcache /tmp/luci-modulecache/* 2>/dev/null || true
	[ -x /etc/init.d/rpcd ] && /etc/init.d/rpcd restart >/dev/null 2>&1 || true
	[ -x /etc/init.d/uhttpd ] && /etc/init.d/uhttpd reload >/dev/null 2>&1 || true
	if [ -x /etc/init.d/mt5700m-manager ]; then
		/etc/init.d/mt5700m-manager enable >/dev/null 2>&1 || true
		# Do not let the procd monitor inherit apk's package-script pipes. A
		# detached delayed restart also allows the package database transaction
		# to finish before the service reads its installed files.
		(sleep 1; /etc/init.d/mt5700m-manager restart) >/dev/null 2>&1 &
	fi
fi

exit 0

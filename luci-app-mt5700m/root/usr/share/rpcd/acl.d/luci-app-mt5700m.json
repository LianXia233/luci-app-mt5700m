{
	"luci-app-mt5700m": {
		"description": "Grant access to MT5700M management",
		"read": {
			"uci": [ "mt5700m" ],
			"ubus": {
				"file": [ "exec" ],
				"mt5700m": [ "status", "log" ],
				"network.device": [ "status" ]
			},
			"file": {
				"/usr/sbin/mt5700m-at": [ "exec" ]
			}
		},
		"write": {
			"uci": [ "mt5700m" ],
			"ubus": {
				"file": [ "exec" ],
				"mt5700m": [ "connect", "disconnect", "redial", "sync" ]
			},
			"file": {
				"/usr/sbin/mt5700m-at": [ "exec" ]
			}
		}
	}
}

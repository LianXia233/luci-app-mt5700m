#!/bin/sh

CONFIG='mt5700m.settings'

if command -v uci >/dev/null 2>&1; then
	enabled="$(uci -q get ${CONFIG}.enabled || echo 1)"
	mode="$(uci -q get ${CONFIG}.mode || echo auto)"
	at_port="$(uci -q get ${CONFIG}.at_port || echo '')"
	host="$(uci -q get ${CONFIG}.host || echo 192.168.8.1)"
	port="$(uci -q get ${CONFIG}.port || echo 20249)"
	timeout_s="$(uci -q get ${CONFIG}.timeout || echo 8)"
else
	enabled=1
	mode=auto
	at_port=
	host=192.168.8.1
	port=20249
	timeout_s=8
fi

case "${timeout_s}" in
	''|*[!0-9]*)
		timeout_s=8
		;;
esac

case "${mode}" in
	auto|serial|network)
		;;
	*)
		mode=auto
		;;
esac

run_with_timeout() {
	local seconds="$1"
	shift

	if command -v timeout >/dev/null 2>&1; then
		timeout "${seconds}" "$@"
	else
		"$@"
	fi
}

detect_modem_gateway() {
	local gateway

	command -v ip >/dev/null 2>&1 || return 1

	gateway="$(ip -4 route show default 2>/dev/null | awk '
		$0 ~ / dev (eth2|usb|wwan|wwan0|qmimux|rmnet|mhi|USB)/ {
			for (i = 1; i <= NF; i++) {
				if ($i == "via") {
					print $(i + 1)
					exit
				}
			}
		}
	')"

	[ -n "${gateway}" ] || gateway="$(ip -4 route show 10.0.0.0/8 2>/dev/null | awk '
		$0 ~ / dev (eth2|usb|wwan|wwan0|qmimux|rmnet|mhi|USB)/ {
			print "10.0.0.1"
			exit
		}
	')"

	[ -n "${gateway}" ] || return 1
	printf '%s\n' "${gateway}"
}

network_hosts() {
	local gateway

	gateway="$(detect_modem_gateway || true)"

	if [ -n "${gateway}" ]; then
		printf '%s\n' "${gateway}"
	fi

	if [ -n "${host}" ] && [ "${host}" != "${gateway}" ]; then
		printf '%s\n' "${host}"
	fi

	if [ "${host}" != "192.168.8.1" ] && [ "${gateway}" != "192.168.8.1" ]; then
		printf '%s\n' "192.168.8.1"
	fi

	if [ "${host}" != "10.0.0.1" ] && [ "${gateway}" != "10.0.0.1" ]; then
		printf '%s\n' "10.0.0.1"
	fi
}

detect_qmodem_at_port() {
	local candidate

	[ -n "${at_port}" ] && [ -e "${at_port}" ] && {
		printf '%s\n' "${at_port}"
		return 0
	}

	command -v uci >/dev/null 2>&1 || return 1

	uci -q show qmodem 2>/dev/null | sed -n "s/.*\.at_port='\([^']*\)'.*/\1/p;s/.*\.at_port=\([^ ]*\).*/\1/p" | while read -r candidate; do
		[ -e "${candidate}" ] || continue
		printf '%s\n' "${candidate}"
		break
	done
}

detect_qmodem_section() {
	local section first value

	command -v uci >/dev/null 2>&1 || return 1

	for section in $(uci -q show qmodem 2>/dev/null | sed -n "s/^qmodem\.\([^.=]*\)=modem-device$/\1/p;s/^qmodem\.\([^.=]*\)='modem-device'$/\1/p"); do
		[ -n "${first}" ] || first="${section}"
		for value in \
			"$(uci -q get qmodem.${section}.at_port)" \
			"$(uci -q get qmodem.${section}.name)" \
			"$(uci -q get qmodem.${section}.manufacturer)" \
			"$(uci -q get qmodem.${section}.platform)" \
			"$(uci -q get qmodem.${section}.path)"; do
			case "${value}" in
				"${at_port}"|*/ttyUSB1|*[Mm][Tt]5700*|*[Hh]uawei*|*[Hh]isilicon*|*/2-1/*)
					printf '%s\n' "${section}"
					return 0
					;;
			esac
		done
	done

	[ -n "${first}" ] || return 1
	printf '%s\n' "${first}"
}

at_network_cmd() {
	local command="$1"
	local target_host="${2:-${host}}"

	if command -v nc >/dev/null 2>&1; then
		printf '%s\r' "${command}" | run_with_timeout "${timeout_s}" nc "${target_host}" "${port}" 2>/dev/null
		return $?
	fi

	echo "nc command not found" >&2
	return 127
}

at_ubus_cmd() {
	local command="$1"
	local device="$2"
	local payload result status response

	command -v ubus >/dev/null 2>&1 || return 127
	command -v jsonfilter >/dev/null 2>&1 || return 127
	[ -r /usr/share/libubox/jshn.sh ] || return 127
	ubus list at-daemon >/dev/null 2>&1 || return 127

	# at-daemon owns the serial descriptor and serializes access shared with
	# QModem. Its default end flags cover OK and standard AT errors.
	. /usr/share/libubox/jshn.sh
	json_init
	json_add_string at_port "${device}"
	json_add_int timeout "${timeout_s}"
	json_add_string at_cmd "${command}"
	payload="$(json_dump)"

	result="$(ubus call at-daemon sendat "${payload}" 2>/dev/null)" || return 1
	status="$(printf '%s' "${result}" | jsonfilter -e '@.status' 2>/dev/null)"
	[ "${status}" = "success" ] || return 1

	response="$(printf '%s' "${result}" | jsonfilter -e '@.response' 2>/dev/null)"
	[ -n "${response}" ] && printf '%s\n' "${response}"
	return 0
}

at_serial_cmd() {
	local command="$1"
	local device="$2"
	local tmp reader elapsed output

	[ -e "${device}" ] || return 1

	if command -v stty >/dev/null 2>&1; then
		stty -F "${device}" 115200 raw -echo -echoe -echok -echoctl -echoke -ixon -ixoff min 0 time 5 2>/dev/null || true
	fi

	run_with_timeout 1 cat "${device}" >/dev/null 2>&1 || true

	tmp="$(mktemp /tmp/mt5700m-at.XXXXXX)" || return 1
	cat "${device}" > "${tmp}" 2>/dev/null &
	reader="$!"

	printf '%s\r' "${command}" > "${device}"

	elapsed=0
	while [ "${elapsed}" -lt "${timeout_s}" ]; do
		output="$(tr -d '\r' < "${tmp}" 2>/dev/null || true)"
		if printf '%s\n' "${output}" | grep -Eq '(^|\n)(OK|ERROR|\+CME ERROR|\+CMS ERROR)(\n|$)'; then
			printf '%s\n' "${output}"
			kill "${reader}" 2>/dev/null || true
			wait "${reader}" 2>/dev/null || true
			rm -f "${tmp}"
			return 0
		fi
		sleep 1
		elapsed=$((elapsed + 1))
	done

	kill "${reader}" 2>/dev/null || true
	wait "${reader}" 2>/dev/null || true
	output="$(tr -d '\r' < "${tmp}" 2>/dev/null || true)"
	rm -f "${tmp}"

	[ -n "${output}" ] && printf '%s\n' "${output}"
	# A serial timeout is a transport failure, not a modem ERROR response.
	# Let auto mode try the network AT endpoint in this case.
	return 124
}

at_cmd() {
	local command="$1"
	local device target serial_output serial_rc ubus_rc

	[ "${enabled}" = "1" ] || return 2
	command="$(printf '%s' "${command}" | tr -d '\000\r\n')"
	[ -n "${command}" ] || return 1

	case "${mode}" in
		serial)
			device="$(detect_qmodem_at_port)"
			[ -n "${device}" ] || {
				echo "AT serial port not found" >&2
				return 1
			}
			at_ubus_cmd "${command}" "${device}"
			ubus_rc=$?
			[ "${ubus_rc}" -eq 0 ] && return 0
			# A live at-daemon owns the descriptor. Do not bypass its lock when
			# a queued request times out or the modem rejects the command.
			[ "${ubus_rc}" -ne 127 ] && return "${ubus_rc}"
			at_serial_cmd "${command}" "${device}"
			return $?
			;;
		network)
			for target in $(network_hosts); do
				at_network_cmd "${command}" "${target}" && return 0
			done
			return 1
			;;
		auto)
			device="$(detect_qmodem_at_port)"
			if [ -n "${device}" ]; then
				at_ubus_cmd "${command}" "${device}"
				ubus_rc=$?
				[ "${ubus_rc}" -eq 0 ] && return 0
				[ "${ubus_rc}" -ne 127 ] && return "${ubus_rc}"
				serial_output="$(at_serial_cmd "${command}" "${device}")"
				serial_rc=$?
				if [ "${serial_rc}" -eq 0 ]; then
					[ -n "${serial_output}" ] && printf '%s\n' "${serial_output}"
					return 0
				fi
			fi

			for target in $(network_hosts); do
				at_network_cmd "${command}" "${target}" && return 0
			done

			return 1
			;;
	esac
}

at_sms_send() {
	local number="$1"
	local text="$2"
	local device section params payload result status

	[ "${enabled}" = "1" ] || return 2
	number="$(printf '%s' "${number}" | tr -cd '0-9+')"
	text="$(printf '%s' "${text}" | tr -d '\000')"
	[ -n "${number}" ] && [ -n "${text}" ] || return 1

	# QModem's SMS method uses the same serialized AT transport as its dialer.
	# Once the request is accepted, never retry through the raw serial path: a
	# retry could send the same message twice when only the response was lost.
	if command -v ubus >/dev/null 2>&1 && command -v jsonfilter >/dev/null 2>&1 && \
		[ -r /usr/share/libubox/jshn.sh ] && ubus list qmodem >/dev/null 2>&1; then
		section="$(detect_qmodem_section || true)"
		if [ -n "${section}" ]; then
			. /usr/share/libubox/jshn.sh
			json_init
			json_add_string phone_number "${number}"
			json_add_string message_content "${text}"
			params="$(json_dump)"
			json_init
			json_add_string config_section "${section}"
			json_add_string params "${params}"
			payload="$(json_dump)"

			result="$(ubus call qmodem send_sms "${payload}" 2>/dev/null)" || return 1
			status="$(printf '%s' "${result}" | jsonfilter -e '@.result.status' 2>/dev/null)"
			[ -n "${status}" ] || status="$(printf '%s' "${result}" | jsonfilter -e '@.status' 2>/dev/null)"
			[ "${status}" = "1" ] || {
				echo "QModem failed to send the message" >&2
				return 1
			}
			printf '%s\n' "${result}"
			return 0
		fi
	fi

	case "${mode}" in
		serial|auto)
			device="$(detect_qmodem_at_port)"
			if [ -n "${device}" ]; then
				if command -v stty >/dev/null 2>&1; then
					stty -F "${device}" 115200 raw -echo -echoe -echok -echoctl -echoke -ixon -ixoff min 0 time 5 2>/dev/null || true
				fi
				(
					printf 'AT+CMGF=1\r' > "${device}"
					sleep 1
					printf 'AT+CMGS="%s"\r' "${number}" > "${device}"
					sleep 1
					printf '%s\032' "${text}" > "${device}"
				) &
				run_with_timeout "$((timeout_s + 20))" cat "${device}" 2>/dev/null | awk '
					{
						gsub(/\r/, "")
						print
					}
					/^OK$/ || /^ERROR$/ || /^\+CME ERROR/ || /^\+CMS ERROR/ {
						exit
					}
				'
				return $?
			fi
			[ "${mode}" = "serial" ] && {
				echo "AT serial port not found" >&2
				return 1
			}
			;;
	esac

	if command -v nc >/dev/null 2>&1; then
		{
			printf 'AT+CMGF=1\r'
			sleep 1
			printf 'AT+CMGS="%s"\r' "${number}"
			sleep 1
			printf '%s\032' "${text}"
		} | run_with_timeout "$((timeout_s + 20))" nc "${host}" "${port}" 2>/dev/null
		return $?
	fi

	echo "nc command not found" >&2
	return 127
}

first_match() {
	sed -n "$1" | head -n 1 | tr -d '\r'
}

clean_value() {
	sed "s/^[[:space:]]*//;s/[[:space:]]*$//;s/^\"//;s/\"$//"
}

clean_line_value() {
	printf '%s' "$1" | sed "s/^[[:space:]]*//;s/[[:space:]]*$//;s/^\"//;s/\"$//"
}

extract_cops_operator() {
	local raw line name

	raw="$1"
	line="$(printf '%s\n' "${raw}" | first_match 's/^+COPS:[[:space:]]*//p')"
	line="$(printf '%s' "${line}" | tr -d '\r')"
	[ -n "${line}" ] || return 1

	name="$(printf '%s' "${line}" | awk -F\" 'NF >= 2 { print $2; exit }')"
	if [ -n "${name}" ]; then
		clean_line_value "${name}"
		return 0
	fi

	name="$(printf '%s' "${line}" | awk -F, '{ print $3 }')"
	name="$(clean_line_value "${name}")"
	[ -n "${name}" ] && {
		printf '%s\n' "${name}"
		return 0
	}

	clean_line_value "${line}"
}

normalize_rat() {
	case "$1" in
		0) echo "GSM" ;;
		2) echo "UTRAN" ;;
		3) echo "GSM EDGE" ;;
		4) echo "HSDPA" ;;
		5) echo "HSUPA" ;;
		6) echo "HSDPA/HSUPA" ;;
		7) echo "LTE" ;;
		9) echo "NR" ;;
		10) echo "LTE-M" ;;
		11) echo "NB-IoT" ;;
		13) echo "LTE" ;;
		20) echo "NR" ;;
		*) clean_line_value "$1" ;;
	esac
}

extract_cops_rat() {
	local raw line rat

	raw="$1"
	line="$(printf '%s\n' "${raw}" | first_match 's/^+COPS:[[:space:]]*//p')"
	line="$(printf '%s' "${line}" | tr -d ' "\r')"
	[ -n "${line}" ] || return 1
	rat="$(printf '%s' "${line}" | awk -F, '{ print $4 }')"
	[ -n "${rat}" ] || return 1
	normalize_rat "${rat}"
}

extract_sysinfo_mode() {
	local raw line mode

	raw="$1"
	line="$(printf '%s\n' "${raw}" | first_match 's/^\^SYSINFOEX:[[:space:]]*//p')"
	line="$(printf '%s' "${line}" | tr -d '\r')"
	[ -n "${line}" ] || return 1

	mode="$(printf '%s' "${line}" | awk -F\" 'NF >= 2 { print $2; exit }')"
	if [ -n "${mode}" ]; then
		clean_line_value "${mode}"
		return 0
	fi

	clean_line_value "${line}"
}

csv_count() {
	local value="$1"

	value="$(printf '%s' "${value}" | tr -d ' ')"
	[ -n "${value}" ] || {
		echo 0
		return
	}

	awk -F, '{ print NF }' <<EOF
${value}
EOF
}

clean_csv() {
	printf '%s' "$1" | tr -d ' ' | sed 's/^,*//;s/,*$//;s/,,*/,/g'
}

valid_numeric_csv() {
	[ -n "$1" ] && printf '%s' "$1" | grep -Eq '^[0-9]+(,[0-9]+)*$'
}

build_lte_lock_command() {
	local lock_type bands arfcns pcis count

	lock_type="${1:-0}"
	bands="$(clean_csv "${2:-}")"
	arfcns="$(clean_csv "${3:-}")"
	pcis="$(clean_csv "${4:-}")"

	case "${lock_type}" in
		0)
			printf '%s\n' 'AT^LTEFREQLOCK=0'
			;;
		3)
			count="$(csv_count "${bands}")"
			valid_numeric_csv "${bands}" || return 64
			printf 'AT^LTEFREQLOCK=3,0,%s,"%s"\n' "${count}" "${bands}"
			;;
		1)
			count="$(csv_count "${bands}")"
			valid_numeric_csv "${bands}" && valid_numeric_csv "${arfcns}" && [ "${count}" = "$(csv_count "${arfcns}")" ] || return 64
			printf 'AT^LTEFREQLOCK=1,0,%s,"%s","%s"\n' "${count}" "${bands}" "${arfcns}"
			;;
		2)
			count="$(csv_count "${bands}")"
			valid_numeric_csv "${bands}" && valid_numeric_csv "${arfcns}" && valid_numeric_csv "${pcis}" && [ "${count}" = "$(csv_count "${arfcns}")" ] && [ "${count}" = "$(csv_count "${pcis}")" ] || return 64
			printf 'AT^LTEFREQLOCK=2,0,%s,"%s","%s","%s"\n' "${count}" "${bands}" "${arfcns}" "${pcis}"
			;;
		*)
			return 64
			;;
	esac
}

build_nr_lock_command() {
	local lock_type bands arfcns scs pcis count

	lock_type="${1:-0}"
	bands="$(clean_csv "${2:-}")"
	arfcns="$(clean_csv "${3:-}")"
	scs="$(clean_csv "${4:-}")"
	pcis="$(clean_csv "${5:-}")"

	case "${lock_type}" in
		0)
			printf '%s\n' 'AT^NRFREQLOCK=0'
			;;
		3)
			count="$(csv_count "${bands}")"
			valid_numeric_csv "${bands}" || return 64
			printf 'AT^NRFREQLOCK=3,0,%s,"%s"\n' "${count}" "${bands}"
			;;
		1)
			count="$(csv_count "${bands}")"
			valid_numeric_csv "${bands}" && valid_numeric_csv "${arfcns}" && valid_numeric_csv "${scs}" && [ "${count}" = "$(csv_count "${arfcns}")" ] && [ "${count}" = "$(csv_count "${scs}")" ] || return 64
			printf 'AT^NRFREQLOCK=1,0,%s,"%s","%s","%s"\n' "${count}" "${bands}" "${arfcns}" "${scs}"
			;;
		2)
			count="$(csv_count "${bands}")"
			valid_numeric_csv "${bands}" && valid_numeric_csv "${arfcns}" && valid_numeric_csv "${scs}" && valid_numeric_csv "${pcis}" && [ "${count}" = "$(csv_count "${arfcns}")" ] && [ "${count}" = "$(csv_count "${scs}")" ] && [ "${count}" = "$(csv_count "${pcis}")" ] || return 64
			printf 'AT^NRFREQLOCK=2,0,%s,"%s","%s","%s","%s"\n' "${count}" "${bands}" "${arfcns}" "${scs}" "${pcis}"
			;;
		*)
			return 64
			;;
	esac
}

print_signal() {
	local raw line fields sys rsrp sinr rsrq

	raw="$(at_cmd 'AT^HCSQ?' || true)"
	line="$(printf '%s\n' "${raw}" | first_match 's/^\^HCSQ:[[:space:]]*//p')"
	line="$(printf '%s' "${line}" | tr -d '"' | tr -d ' ')"
	[ -n "${line}" ] || return 0

	IFS=,
	set -- ${line}
	IFS=' '
	sys="$1"
	rsrp="$2"
	sinr="$3"
	rsrq="$4"

	[ -n "${sys}" ] && echo "sysmode=${sys}"
	if printf '%s' "${rsrp:-}" | grep -Eq '^[0-9]+$'; then
		[ "${rsrp}" = "255" ] && echo "rsrp=" || echo "rsrp=$((rsrp - 140))"
	fi
	if printf '%s' "${sinr:-}" | grep -Eq '^[0-9]+$'; then
		case "${sinr}" in
			255)
				echo "sinr="
				;;
			251)
				echo "sinr=>=30.0"
				;;
			*)
				awk -v v="${sinr}" 'BEGIN { printf "sinr=%.1f\n", -20 + v * 0.2 }'
				;;
		esac
	fi
	if printf '%s' "${rsrq:-}" | grep -Eq '^[0-9]+$'; then
		case "${rsrq}" in
			255)
				echo "rsrq="
				;;
			34)
				echo "rsrq=>=-3"
				;;
			*)
				awk -v v="${rsrq}" 'BEGIN { printf "rsrq=%.1f\n", -19.5 + v * 0.5 }'
				;;
		esac
	fi
}

print_identity() {
	local raw

	raw="$(at_cmd 'ATI' || true)"
	printf '%s\n' "${raw}" | first_match 's/^Manufacturer:[[:space:]]*//p' | clean_value | sed 's/^/manufacturer=/'
	printf '%s\n' "${raw}" | first_match 's/^Model:[[:space:]]*//p' | clean_value | sed 's/^/model=/'
	printf '%s\n' "${raw}" | first_match 's/^Revision:[[:space:]]*//p' | clean_value | sed 's/^/revision=/'
	printf '%s\n' "${raw}" | first_match 's/^IMEI:[[:space:]]*//p' | clean_value | sed 's/^/imei=/'
}

print_sim_operator() {
	local sim cops operator rat sysinfo sysmode

	sim="$(at_cmd 'AT+CPIN?' || true)"
	printf '%s\n' "${sim}" | first_match 's/^+CPIN:[[:space:]]*//p' | clean_value | sed 's/^/sim=/'

	cops="$(at_cmd 'AT+COPS?' || true)"
	operator="$(extract_cops_operator "${cops}" || true)"
	[ -n "${operator}" ] && echo "operator=${operator}"
	rat="$(extract_cops_rat "${cops}" || true)"
	[ -n "${rat}" ] && echo "sysmode=${rat}"

	sysinfo="$(at_cmd 'AT^SYSINFOEX' || true)"
	sysmode="$(extract_sysinfo_mode "${sysinfo}" || true)"
	[ -n "${sysmode}" ] && echo "sysmode_detail=${sysmode}"
}

print_temperature() {
	local raw value

	raw="$(at_cmd 'AT^CHIPTEMP?' || true)"
	value="$(printf '%s\n' "${raw}" | first_match 's/^\^CHIPTEMP:[[:space:]]*//p' | awk -F, '{print $1}' | grep -Eo -- '-?[0-9]+' | head -n 1)"
	[ -n "${value}" ] || return 0
	awk -v v="${value}" 'BEGIN { printf "temperature=%.1f\n", v / 10 }'
}

print_lock_status() {
	local raw

	raw="$(at_cmd 'AT^NRFREQLOCK?' || true)"
	printf '%s\n' "${raw}" | first_match 's/^\^NRFREQLOCK:[[:space:]]*//p' | clean_value | sed 's/^/nr_lock=/'

	raw="$(at_cmd 'AT^LTEFREQLOCK?' || true)"
	printf '%s\n' "${raw}" | first_match 's/^\^LTEFREQLOCK:[[:space:]]*//p' | clean_value | sed 's/^/lte_lock=/'
}

print_network_info() {
	local label command raw

	for item in \
		"Signal|AT^HCSQ?" \
		"Serving cell|AT^MONSC" \
		"Frequency info|AT^HFREQINFO?" \
		"Network registration|AT+CEREG?" \
		"Operator|AT+COPS?" \
		"LTE lock|AT^LTEFREQLOCK?" \
		"NR lock|AT^NRFREQLOCK?"
	do
		label="${item%%|*}"
		command="${item#*|}"
		echo "===== ${label}: ${command} ====="
		raw="$(at_cmd "${command}" || true)"
		printf '%s\n\n' "${raw}"
	done
}

print_sms_list() {
	echo "===== SMS storage ====="
	at_cmd 'AT+CPMS?' || true
	echo
	echo "===== SMS messages ====="
	# MT5700M text mode omits the message body for stored UCS2 messages.
	# PDU mode preserves the complete payload for decoding in LuCI.
	at_cmd 'AT+CMGF=0' >/dev/null 2>&1 || true
	at_cmd 'AT+CMGL=4' || true
}

print_system_info() {
	local label command raw

	for item in \
		"Identity|ATI" \
		"IMEI|AT+CGSN" \
		"Revision|AT+CGMR" \
		"Version|AT^VERSION?" \
		"SIM|AT+CPIN?" \
		"Operator|AT+COPS?" \
		"FOTA mode|AT^FOTAMODE?" \
		"FOTA state|AT^FOTASTATE?" \
		"FOTA progress|AT^FOTADLQ" \
		"Temperature|AT^CHIPTEMP?"
	do
		label="${item%%|*}"
		command="${item#*|}"
		echo "===== ${label}: ${command} ====="
		raw="$(at_cmd "${command}" || true)"
		printf '%s\n\n' "${raw}"
	done
}

print_advanced_info() {
	local label command raw

	for item in \
		"Auto dial|AT^SETAUTODIAL?" \
		"Direct IP|AT^SETDIRECTIP?" \
		"USB mode|AT^SETMODE?" \
		"Interface mode|AT^TDCFG?" \
		"PDP contexts|AT+CGDCONT?" \
		"Radio mode|AT^SYSCFGEX?" \
		"NIC speed|AT^TDPCIELANCFG?" \
		"Performance mode|AT^TDPMCFG?" \
		"SIM hotplug|AT^TDSIMHP?" \
		"SIM slot|AT^SCICHG?" \
		"Thermal control|AT^THERMAUTOFUN?" \
		"NR carrier aggregation|AT^NRRCCAPQRY=3" \
		"VoNR|AT^NRRCCAPQRY=2" \
		"DSS|AT^NRRCCAPQRY=5"
	do
		label="${item%%|*}"
		command="${item#*|}"
		echo "===== ${label}: ${command} ====="
		raw="$(at_cmd "${command}" || true)"
		printf '%s\n\n' "${raw}"
	done
}

print_sms_info() {
	local label command raw

	for item in \
		"IMS|AT^IMSSWITCH?" \
		"SMSC|AT+CSCA?" \
		"Storage|AT+CPMS?"
	do
		label="${item%%|*}"
		command="${item#*|}"
		echo "===== ${label}: ${command} ====="
		raw="$(at_cmd "${command}" || true)"
		printf '%s\n\n' "${raw}"
	done
}

safe_at_field() {
	case "$1" in
		*'"'*|*','*|*'\r'*|*'\n'*) return 1 ;;
	esac
	return 0
}

case "${1:-status}" in
	status)
		# Keep LuCI status below rpcd's execution timeout even if an optional
		# modem query does not return a final result promptly.
		[ "${timeout_s}" -le 2 ] || timeout_s=2
		echo "enabled=${enabled}"
		echo "mode=${mode}"
		detected_at_port="$(detect_qmodem_at_port || true)"
		echo "at_port=${detected_at_port:-${at_port}}"
		echo "host=${host}"
		echo "port=${port}"
		detected_gateway="$(detect_modem_gateway || true)"
		echo "detected_gateway=${detected_gateway}"
		if [ "${mode}" = "network" ]; then
			echo "channel=network"
		elif [ -n "${detected_at_port}" ]; then
			echo "channel=serial"
		else
			echo "channel=network"
		fi
		if at_cmd 'AT' | grep -q 'OK'; then
			echo "connected=1"
		else
			echo "connected=0"
		fi
		print_identity
		print_sim_operator
		print_signal
		print_temperature
		print_lock_status
		;;
	command)
		shift
		at_cmd "$*"
		;;
	network)
		print_network_info
		;;
	cellscan)
		at_cmd 'AT^CELLSCAN=3'
		;;
	sms-list)
		print_sms_list
		;;
	sms-info)
		print_sms_info
		;;
	sms-send)
		shift
		at_sms_send "${1:-}" "${2:-}"
		;;
	sms-delete)
		shift
		index="$(printf '%s' "${1:-}" | tr -cd '0-9')"
		[ -n "${index}" ] || exit 1
		at_cmd "AT+CMGD=${index}"
		;;
	sms-clear)
		at_cmd 'AT+CMGF=0' >/dev/null || exit 1
		at_cmd 'AT+CMGD=1,4'
		;;
	sms-set)
		shift
		case "${1:-}" in
			smsc)
				shift
				smsc="$(printf '%s' "${1:-}" | tr -cd '0-9+')"
				[ -n "${smsc}" ] || exit 64
				at_cmd "AT+CSCA=\"${smsc}\""
				;;
			storage)
				shift
				case "${1:-}" in SM|ME) store="${1}" ;; *) exit 64 ;; esac
				at_cmd "AT+CPMS=\"${store}\",\"${store}\",\"${store}\""
				;;
			*) exit 64 ;;
		esac
		;;
	system)
		print_system_info
		;;
	advanced)
		print_advanced_info
		;;
	advanced-set)
		shift
		case "${1:-}" in
			autodial)
				shift
				enable="${1:-}"
				dial_mode="${2:-}"
				protocol="${3:-}"
				apn="${4:-}"
				username="${5:-}"
				password="${6:-}"
				auth_type="${7:-}"
				case "${enable}" in 0|1) ;; *) exit 64 ;; esac
				case "${dial_mode}" in 1|2) ;; *) exit 64 ;; esac
				case "${protocol}" in IP|IPV6|IPV4V6) ;; *) exit 64 ;; esac
				case "${auth_type}" in 0|1|2) ;; *) exit 64 ;; esac
				safe_at_field "${apn}" && safe_at_field "${username}" && safe_at_field "${password}" || exit 64
				at_cmd "AT^SETAUTODIAL=${enable},${dial_mode},\"${protocol}\",\"${apn}\",\"${username}\",\"${password}\",${auth_type}"
				;;
			direct-ip)
				shift
				case "${1:-}" in 0|1) at_cmd "AT^SETDIRECTIP=${1}" ;; *) exit 64 ;; esac
				;;
			nic-speed)
				shift
				case "${1:-}" in 1|2) at_cmd "AT^TDPCIELANCFG=${1}" ;; *) exit 64 ;; esac
				;;
			usb-mode)
				shift
				case "${1:-}" in 0|1|2|3|4|5|6|7|8) at_cmd "AT^SETMODE=${1}" ;; *) exit 64 ;; esac
				;;
			interface-mode)
				shift
				case "${1:-}" in 1|2|3) at_cmd "AT^TDCFG=\"infcfg\",\"mode\",${1}" ;; *) exit 64 ;; esac
				;;
			postroute)
				shift
				case "${1:-}" in
					0) at_cmd 'AT^TDCFG="infcfg","PostRoute",0' ;;
					1) at_cmd 'AT^IPFILTERSWITCH=0' >/dev/null || exit 1; at_cmd 'AT^TDCFG="infcfg","PostRoute",1' ;;
					*) exit 64 ;;
				esac
				;;
			dmz)
				shift
				dmz="${1:-}"
				case "${dmz}" in
					0) at_cmd 'AT^TDCFG="infcfg","dmz","0"' ;;
					192.168.8.*) printf '%s' "${dmz}" | grep -Eq '^192\.168\.8\.([1-9]|[1-9][0-9]|1[0-9][0-9]|2[0-4][0-9]|25[0-4])$' || exit 64; at_cmd "AT^TDCFG=\"infcfg\",\"dmz\",\"${dmz}\"" ;;
					*) exit 64 ;;
				esac
				;;
			performance)
				shift
				case "${1:-}" in 0|1) at_cmd "AT^TDPMCFG=${1},0,0,0" ;; *) exit 64 ;; esac
				;;
			sim-hotplug)
				shift
				case "${1:-}" in 0|1) at_cmd "AT^TDSIMHP=${1}" ;; *) exit 64 ;; esac
				;;
			thermal)
				shift
				case "${1:-}" in 0|1) thermal_enabled="${1}" ;; *) exit 64 ;; esac
				case "${2:-}" in 0|1) thermal_mimo="${2}" ;; *) exit 64 ;; esac
				case "${3:-}" in 1|2|3|4|5|10|15|30|60) thermal_interval="${3}" ;; *) exit 64 ;; esac
				at_cmd "AT^THERMAUTOFUN=${thermal_enabled},${thermal_mimo},${thermal_interval}"
				;;
			carrier-aggregation)
				shift
				case "${1:-}" in 0|1) at_cmd "AT^NRRCCAPCFG=3,${1}" ;; *) exit 64 ;; esac
				;;
			vonr)
				shift
				case "${1:-}" in 0|1|2|3) at_cmd "AT^NRRCCAPCFG=2,${1}" ;; *) exit 64 ;; esac
				;;
			dss)
				shift
				case "${1:-}" in 0|1) dss_rate="${1}" ;; *) exit 64 ;; esac
				case "${2:-}" in 0|1) dss_dmrs="${2}" ;; *) exit 64 ;; esac
				at_cmd "AT^NRRCCAPCFG=5,${dss_rate},${dss_dmrs}"
				;;
			*)
				exit 64
				;;
		esac
		;;
	fota-init)
		at_cmd 'AT^FOTAMODE=0,1,0,1'
		;;
	fota-state)
		at_cmd 'AT^FOTASTATE?'
		;;
	fota-progress)
		at_cmd 'AT^FOTADLQ'
		;;
	fota-download)
		shift
		url="$(printf '%s' "${1:-}" | tr -d '\000\r\n"')"
		[ -n "${url}" ] || exit 1
		at_cmd "AT^FOTAOEMDL=\"${url}\""
		;;
	fota-start)
		shift
		url="$(printf '%s' "${1:-}" | tr -d '\000\r\n"')"
		case "${url}" in http://*) ;; *) exit 64 ;; esac
		case "${url}" in *,*) exit 64 ;; esac
		case "${url}" in */) ;; *) url="${url}/" ;; esac
		at_cmd 'ATE0' >/dev/null || exit 1
		at_cmd 'AT^FOTAMODE=0,1,0,1' >/dev/null || exit 1
		at_cmd "AT^FOTAOEMDL=\"${url}\""
		;;
	fota-resume)
		at_cmd 'AT^FOTADL=1'
		;;
	fota-upgrade)
		at_cmd 'AT^FWUP'
		;;
	preview-lock)
		shift
		case "${1:-}" in
			lte)
				shift
				build_lte_lock_command "$@" || exit 64
				;;
			nr)
				shift
				build_nr_lock_command "$@" || exit 64
				;;
			*)
				echo "Usage: $0 preview-lock {lte|nr} <type> <bands> [arfcns] [scs] [pcis]" >&2
				exit 1
				;;
		esac
		;;
	lock)
		lock_cmd=''
		shift
		case "${1:-}" in
			lte)
				shift
				lock_cmd="$(build_lte_lock_command "$@")" || exit 64
				;;
			nr)
				shift
				lock_cmd="$(build_nr_lock_command "$@")" || exit 64
				;;
			*)
				echo "Usage: $0 lock {lte|nr} <type> <bands> [arfcns] [scs] [pcis]" >&2
				exit 1
				;;
		esac
		[ -n "${lock_cmd}" ] || exit 64
		at_cmd "${lock_cmd}"
		;;
	restart)
		at_cmd 'AT+CFUN=1,1'
		;;
	unlock)
		echo "Unlock LTE:"
		at_cmd 'AT^LTEFREQLOCK=0'
		echo "Unlock NR:"
		at_cmd 'AT^NRFREQLOCK=0'
		;;
	*)
		echo "Usage: $0 {status|command <AT>|restart|unlock}" >&2
		exit 1
		;;
esac

exit 0
